# Build inputs — not needed in packaged extension
src/**
out/**
node_modules/**

# Config & tooling
.vscode/**
.vscode-test/**
.github/**
docs/**
webpack.config.js
tsconfig.json
.eslintrc.json
eslint.config.js
.eslintignore
CLAUDE.md
.gitignore
.yarnrc
.npmrc

# Test artifacts
**/*.test.ts
**/*.spec.ts
test/**
coverage/**

# Docs / meta (keep README.md and LICENSE)
vsc-extension-quickstart.md
CHANGELOG.md
CONTRIBUTING.md

# Source maps & TypeScript output
**/*.map
**/*.ts

# npm lockfile (not needed inside .vsix)
package-lock.json

# Misc
*.vsix
*.log
