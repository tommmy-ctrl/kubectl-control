{
  "name": "kubectl-control",
  "displayName": "Kubectl Control",
  "description": "Manage multiple Kubernetes clusters with isolated kubeconfig terminals, group support, and encrypted export/import.",
  "version": "1.0.0",
  "author": "Tom Kölsch",
  "publisher": "tommmy-ctrl",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tommmy-ctrl/kubectl-control"
  },
  "bugs": {
    "url": "https://github.com/tommmy-ctrl/kubectl-control/issues"
  },
  "keywords": [
    "kubernetes",
    "kubectl",
    "kubeconfig",
    "k8s",
    "cluster",
    "terminal",
    "devops"
  ],
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kubectl-control.addCluster",
        "title": "Verbindung hinzufügen",
        "icon": "$(add)"
      },
      {
        "command": "kubectl-control.deleteCluster",
        "title": "Verbindung löschen",
        "icon": "$(trash)"
      },
      {
        "command": "kubectl-control.editCluster",
        "title": "Verbindung bearbeiten",
        "icon": "$(edit)"
      },
      {
        "command": "kubectl-control.openTerminal",
        "title": "Terminal öffnen"
      },
      {
        "command": "kubectl-control.settingsMenu",
        "title": "Einstellungen",
        "icon": "$(gear)"
      },
      {
        "command": "kubectl-control.quickSwitch",
        "title": "Kubectl Control: Quick Switch Cluster"
      },
      {
        "command": "kubectl-control.showLogs",
        "title": "Kubectl Control: Show Debug Logs"
      },
      {
        "command": "kubectl-control.syncNow",
        "title": "Kubectl Control: GitHub Sync – Jetzt synchronisieren"
      },
      {
        "command": "kubectl-control.syncRestore",
        "title": "Kubectl Control: GitHub Sync – Von GitHub wiederherstellen"
      },
      {
        "command": "kubectl-control.syncDisable",
        "title": "Kubectl Control: GitHub Sync – Deaktivieren"
      },
      {
        "command": "kubectl-control.switchNamespace",
        "title": "Kubectl Control: Namespace wechseln"
      },
      {
        "command": "kubectl-control.togglePin",
        "title": "Kubectl Control: Cluster anpinnen / losgelöst"
      },
      {
        "command": "kubectl-control.toggleProd",
        "title": "Kubectl Control: Als Produktionsumgebung markieren"
      }
    ],
    "configuration": {
      "title": "Kubectl Control",
      "properties": {
        "kubectl-control.autoLockMinutes": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Minuten bis zur automatischen Sperrung bei Inaktivität (0 = deaktiviert)"
        }
      }
    },
    "keybindings": [
      {
        "command": "kubectl-control.quickSwitch",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kubectl-control-explorer",
          "title": "Kubectl Control",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "kubectl-control-explorer": [
        {
          "type": "webview",
          "id": "kubectl-control.connectionsView",
          "name": "Verbindungen"
        },
        {
          "id": "kubectl-control.clustersView",
          "name": "Clusters",
          "when": "kubectl-control.showClusters"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "kubectl-control.settingsMenu",
          "when": "view == kubectl-control.connectionsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "kubectl-control.editCluster",
          "when": "view == kubectl-control.clustersView && viewItem == cluster",
          "group": "inline@1"
        },
        {
          "command": "kubectl-control.deleteCluster",
          "when": "view == kubectl-control.clustersView && viewItem == cluster",
          "group": "inline@2"
        },
        {
          "command": "kubectl-control.togglePin",
          "when": "view == kubectl-control.clustersView && viewItem == cluster",
          "group": "1_actions@1"
        },
        {
          "command": "kubectl-control.toggleProd",
          "when": "view == kubectl-control.clustersView && viewItem == cluster",
          "group": "1_actions@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "uuid": "^14.0.1"
  }
}
