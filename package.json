{
  "name": "kubectl-control",
  "displayName": "Kubectl Control",
  "description": "Manage multiple kubectl terminals with isolated configs",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kubectl-control.addCluster",
        "title": "Add Cluster",
        "icon": "$(add)"
      },
      {
        "command": "kubectl-control.deleteCluster",
        "title": "Delete Cluster",
        "icon": "$(trash)"
      },
      {
        "command": "kubectl-control.openTerminal",
        "title": "Open Terminal"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kubectl-control-explorer",
          "title": "Kubectl Control",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "kubectl-control-explorer": [
        {
          "id": "kubectl-control.clustersView",
          "name": "Clusters"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "kubectl-control.addCluster",
          "when": "view == kubectl-control.clustersView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "kubectl-control.deleteCluster",
          "when": "view == kubectl-control.clustersView",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  },
  "dependencies": {
    "uuid": "^9.0.0"
  }
}
